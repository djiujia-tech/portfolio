      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Roboto:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="css/reset.css" />
    <link rel="stylesheet" href="css/style.css" />
  </head>

  <body>
    <header class="l-header">
      <h1 class="header-logo">
        <a href="index.html" class="u-nav-link">
          <div class="header-logo-img-box">
            <img
              src="img/portfolio_logo.png"
              alt="logo"
              height="1312"
              width="816"
              class="l-header-logo_img"
            />
          </div>
        </a>
      </h1>
      <nav class="l-header__nav">
        <ul class="l-header__nav-list">
          <li><a href="works.html">Works</a></li>
          <li><a href="about.html">About</a></li>
          <li><a href="contact.html">Contact</a></li>
        </ul>
      </nav>

      <button
        class="m-header-hamburger"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </header>

    <main class="l_main">
      <section class="contact">
        <div class="l_container">
          <div class="m_section-title">
            <span class="m_section-title__sub">contact</span>
            <h2 class="m_section-title__main">お問い合わせ</h2>
          </div>

          <p class="contact__lead">
            Web制作・予約システムの導入など、お気軽にご相談ください。<br />
            通常2〜3営業日以内にご返信いたします。
          </p>

          <form class="contact__form" action="https://formspree.io/f/mojongdz" method="POST">
            <div class="contact__field">
              <label class="contact__label" for="name">
                お名前
                <span class="contact__required">（必須）</span>
              </label>
              <input
                class="contact__input"
                type="text"
                id="name"
                name="name"
                placeholder="山田 太郎"
                required
              />
            </div>

            <div class="contact__field">
              <label class="contact__label" for="email">
                メールアドレス
                <span class="contact__required">（必須）</span>
              </label>
              <input
                class="contact__input"
                type="email"
                id="email"
                name="email"
                placeholder="example@email.com"
                required
              />
            </div>

            <div class="contact__field">
              <label class="contact__label" for="subject">お問い合わせ種別</label>
              <select class="contact__input contact__select" id="subject" name="subject">
                <option value="">選択してください</option>
                <option value="web">Web制作について</option>
                <option value="cue">予約システム（CUE）について</option>
                <option value="both">Web制作＋予約システムのセットについて</option>
                <option value="other">その他</option>
              </select>
            </div>

            <div class="contact__field">
              <label class="contact__label" for="message">
                メッセージ
                <span class="contact__required">（必須）</span>
              </label>
              <textarea
                class="contact__textarea"
                id="message"
                name="message"
                placeholder="ご依頼内容やご質問をご記入ください"
                rows="6"
                required
              ></textarea>
            </div>

            <div class="contact__submit">
              <button type="submit" class="m_button">送信する</button>
            </div>
          </form>

          <div class="contact__line">
            <p class="contact__line-text">LINEでのお問い合わせはこちら</p>
            <a
              href="https://lin.ee/YFcY1R5"
              target="_blank"
              rel="noopener noreferrer"
              class="m_button m_button__line"
            >LINEで相談する</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="l-footer">
      <nav class="l-footer__nav">
        <ul class="l-footer__nav-list">
          <li class="l-footer__nav-item">
            <a href="index.html" class="l-footer__nav-link">Top</a>
          </li>
          <li class="l-footer__nav-item">
            <a href="works.html" class="l-footer__nav-link">Works</a>
          </li>
          <li class="l-footer__nav-item">
            <a href="about.html" class="l-footer__nav-link">About</a>
          </li>
          <li class="l-footer__nav-item">
            <a href="contact.html" class="l-footer__nav-link">Contact</a>
          </li>
        </ul>
      </nav>
      <p class="l-footer__copyright">
        <small>© 2026 Gaku</small>
      </p>
    </footer>

    <script src="js/main.js" defer></script>
  </body>
</html>
